+import { useGetTagsQuery } from '@api/tagsAPI'
+import {
+  getPaddingValuesForVirtualizeTable,
+  PaddingForVirtualizeTable
+} from '@components/Table/PaddingForVirtualizeTable'
+import { TableWithSelectableRowsHeader } from '@components/Table/TableWithSelectableRows/OldHeader'
+import { BackofficeWrapper, Title, TitleContainer } from '@features/BackOffice/components/style'
+import { TAG_TABLE_COLUMNS } from '@features/Tags/components/Table/constants'
+import { useTable } from '@hooks/useTable'
+import { useTableVirtualizer } from '@hooks/useTableVirtualizer'
+import { Button, SimpleTable } from '@mtes-mct/monitor-ui'
+import { useMemo, useRef, useState } from 'react'
+
+import { FilterBar } from './FilterBar'
+import { Row } from './Row'
+import { getFilters } from './utils'
+import { RTK_DEFAULT_QUERY_OPTIONS } from '../../../../api/constants'
+import { useAppSelector } from '../../../../hooks/useAppSelector'
+
+import type { TagFromAPI } from '../../../../domain/entities/tags'
+import type { SortingState } from '@tanstack/react-table'
+import type { Row as RowType } from '@tanstack/table-core/build/lib/types'
+
+export function TagTable() {
+  const tagFilters = useAppSelector(store => store.tagTable.filtersState)
+  const { data: entityTags } = useGetTagsQuery(undefined, RTK_DEFAULT_QUERY_OPTIONS)
+
+  const filteredTags = useMemo(() => {
+    const tags = Object.values(entityTags ?? [])
+    if (!tags) {
+      return undefined
+    }
+
+    const filters = getFilters(tags, tagFilters)
+
+    return filters
+      .reduce((previousTags: TagFromAPI[], filter) => filter(previousTags), tags)
+      .map(tag => ({
+        ...tag,
+        subRows: tag.subTags
+      }))
+  }, [tagFilters, entityTags])
+
+  const [sorting, setSorting] = useState<SortingState>([])
+
+  const columns = TAG_TABLE_COLUMNS
+  const table = useTable({
+    columns,
+    data: filteredTags,
+    setSorting,
+    sorting,
+    withRowSelection: false
+  })
+  const tableContainerRef = useRef<HTMLDivElement>(null)
+
+  const { rows } = table.getRowModel()
+  const rowVirtualizer = useTableVirtualizer({ estimateSize: 30, ref: tableContainerRef, rows })
+
+  const virtualRows = rowVirtualizer.getVirtualItems()
+
+  const [before, after] = getPaddingValuesForVirtualizeTable(virtualRows, rowVirtualizer)
+
+  return (
+    <BackofficeWrapper>
+      <TitleContainer>
+        <Title>Tags</Title>
+        <Button>Ajouter un nouveau tag</Button>
+      </TitleContainer>
+
+      <FilterBar />
+
+      {/* <DataTable columns={TAG_TABLE_COLUMNS} data={filteredTags} initialSorting={[{ desc: false, id: 'name' }]} /> */}
+      <div ref={tableContainerRef}>
+        <SimpleTable.Table>
+          <SimpleTable.Head>
+            {table.getHeaderGroups().map(headerGroup => (
+              <TableWithSelectableRowsHeader key={headerGroup.id} headerGroup={headerGroup} />
+            ))}
+          </SimpleTable.Head>
+          {before > 0 && <PaddingForVirtualizeTable columLength={columns.length} height={before} name="before" />}
+          <tbody>
+            {virtualRows?.map(virtualRow => {
+              const row = rows[virtualRow.index] as RowType<TagFromAPI>
+
+              return <Row key={virtualRow.key} row={row} />
+            })}
+          </tbody>
+          {after > 0 && <PaddingForVirtualizeTable columLength={columns.length} height={after} name="after" />}
+        </SimpleTable.Table>
+      </div>
+    </BackofficeWrapper>
+  )
+}
